# EastXperience WA Bot — Environment Variables
# Copy this file to .env and fill in the values

# Dari dashboard fonnte.com → Settings → API Token
FONNTE_TOKEN=your_fonnte_token_here

# Dari console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port (Railway/Render auto-set ini, jangan ubah)
PORT=3000

# Secret untuk endpoint /broadcast (buat password random kamu sendiri)
BROADCAST_SECRET=eastxperience_broadcast_2026
